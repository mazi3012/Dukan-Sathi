# Dukan Sathi Pro - Environment Configuration Template
# Copy this to .env and fill in your actual values
# NEVER commit .env to version control

# ─── AI CONFIGURATION ───────────────────────────────────────────────────
# Unified model ID used everywhere in the app.
# Example: meta-llama/llama-4-scout-17b-16e-instruct
MODEL_ID=meta-llama/llama-4-scout-17b-16e-instruct

# Groq API Configuration
# Setting this switches the AI provider to Groq.
GROQ_API_KEY=your-groq-api-key

# ─── TELEGRAM BOT CONFIGURATION ─────────────────────────────────────────────
# Get this from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=123456789:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# ─── SUPABASE CONFIGURATION ─────────────────────────────────────────────────
# Required for database and multi-tenant features.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Service role key is required for backend-only onboarding operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── SERVER CONFIGURATION ───────────────────────────────────────────────────
# Default: 4000 for local dev scripts
# Default: 3100 for production genkit_server.dart
PORT=3100

# Logging Level
# Options: debug, info, warning, error
LOG_LEVEL=info


