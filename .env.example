# Dukan Sathi Pro - Environment Configuration Template
# Copy this to .env and fill in your actual values
# NEVER commit .env to version control

# Google Cloud Project Configuration
# Get this from your GCP project settings
GCLOUD_PROJECT=your-gcp-project-id

# GCP Location for Vertex AI
# Common values: us-central1, us-west1, europe-west1
GCLOUD_LOCATION=us-central1

# Path to Google Cloud Service Account JSON file
# Generate this in your GCP project > Service Accounts
# Example: /home/user/path/to/service-account.json
# This file should have permissions for Vertex AI API
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Telegram Bot Token
# Get this from BotFather on Telegram
# Format: <numbers>:<alphanumeric_string>
# Example: REDACTED-TOKEN-REMOVED
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Supabase Configuration (Optional)
# Only needed if using Supabase for database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Port Configuration (Optional)
# Default: 4000 for genkit_dev.dart
# Default: 3100 for genkit_server.dart
PORT=4000

# Logging Level (Optional)
# Options: debug, info, warning, error
LOG_LEVEL=info
