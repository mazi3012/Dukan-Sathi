# Dukan Sathi Pro - Environment Configuration Template
# Copy this to .env and fill in your actual values
# NEVER commit .env to version control

# Unified model ID used everywhere in the app
# Set any supported Gemini model ID here.
MODEL_ID=gemini-3.1-flash-lite-preview

# Google GenAI SDK API key (choose one)
# GOOGLE_API_KEY is preferred; GEMINI_API_KEY is also supported.
GOOGLE_API_KEY=your-google-genai-api-key
# GEMINI_API_KEY=your-google-genai-api-key

# Telegram Bot Token
# Get this from BotFather on Telegram
# Format: <numbers>:<alphanumeric_string>
# DO NOT share your actual token - example format only: 123456789:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Supabase Configuration (Optional)
# Only needed if using Supabase for database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Port Configuration (Optional)
# Default: 4000 for genkit_dev.dart
# Default: 3100 for genkit_server.dart
PORT=4000

# Logging Level (Optional)
# Options: debug, info, warning, error
LOG_LEVEL=info
