{
  "version": 2,
  "public": true,
  "name": "dukan-sathi-pro",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://dukan-sathi-pro.onrender.com/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "outputDirectory": "build/web",
  "buildCommand": "bash vercel-build.sh",
  "installCommand": "echo 'handled in buildCommand'"
}
